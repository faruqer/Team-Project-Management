# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/orbit?schema=public"

# API
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Orbit <noreply@orbit.app>"

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Platform admin (comma-separated emails granted cross-tenant admin access)
PLATFORM_ADMIN_EMAILS=admin@orbit.app
