{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @orbit/api\" \"npm run dev -w @orbit/web\"",
    "dev:api": "npm run dev -w @orbit/api",
    "dev:web": "npm run dev -w @orbit/web",
    "build": "npm run build -w @orbit/api && npm run build -w @orbit/web",
    "lint": "npm run lint -w @orbit/api && npm run lint -w @orbit/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npm run db:generate -w @orbit/api",
    "db:migrate": "npm run db:migrate -w @orbit/api",
    "db:push": "npm run db:push -w @orbit/api",
    "test": "npm run test -w @orbit/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.0"
  }
}
